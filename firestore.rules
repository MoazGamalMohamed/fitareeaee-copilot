rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    function validOwnerAvatar(uid) {
      let photoUrl = request.resource.data.get('photoUrl', null);
      return photoUrl == null
        || (photoUrl is string
          && photoUrl.size() <= 2048
          && photoUrl.matches(
            'https://firebasestorage[.]googleapis[.]com/v0/b/fitareeaee[.]firebasestorage[.]app/o/avatars%2F'
              + uid
              + '%2Fprofile[.]jpg[?]alt=media&token=[A-Za-z0-9_-]+'
          ));
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.id == uid
        && request.resource.data.isVerified == false
        && request.resource.data.isEmailVerified == false
        && request.resource.data.isPhoneVerified == false
        && request.resource.data.rating == 5
        && request.resource.data.totalRatings == 0
        && request.resource.data.totalTrips == 0;
      allow update: if isOwner(uid)
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'phone', 'bio', 'address', 'city', 'country',
          'latitude', 'longitude', 'isProfileComplete', 'metadata',
          'photoUrl', 'updatedAt', 'updated_at'
        ])
        && validOwnerAvatar(uid);
      allow delete: if false;
    }

    match /public_profiles/{uid} {
      allow get: if signedIn();
      allow list: if false;
      allow write: if false;
    }

    match /trips/{tripId} {
      allow get: if signedIn()
        && (resource.data.driverId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }

    match /public_trips/{tripId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /bookings/{bookingId} {
      allow read: if signedIn()
        && (resource.data.passengerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
          || isAdmin());
      allow write: if false;
    }

    match /verifications/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /verification_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /messages/{messageId} {
      allow read: if signedIn()
        && resource.data.participant_ids is list
        && request.auth.uid in resource.data.participant_ids
        && exists(/databases/$(database)/documents/conversation_authorizations/$(resource.data.conversation_id))
        && get(/databases/$(database)/documents/conversation_authorizations/$(resource.data.conversation_id)).data.participant_ids
          == resource.data.participant_ids;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'id', 'sender_id', 'recipient_id', 'conversation_id',
          'participant_ids', 'content', 'attachments', 'created_at',
          'is_read', 'read_at', 'is_deleted'
        ])
        && request.resource.data.id == messageId
        && request.resource.data.sender_id == request.auth.uid
        && request.resource.data.recipient_id is string
        && request.resource.data.recipient_id != request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() == 0
        && request.resource.data.created_at is timestamp
        && request.resource.data.read_at == null
        && request.resource.data.conversation_id is string
        && request.resource.data.conversation_id.size() > 0
        && request.resource.data.conversation_id.size() <= 512
        && request.resource.data.participant_ids is list
        && request.resource.data.participant_ids.size() == 2
        && request.resource.data.participant_ids.hasAll([
          request.auth.uid,
          request.resource.data.recipient_id
        ])
        && exists(/databases/$(database)/documents/conversation_authorizations/$(request.resource.data.conversation_id))
        && get(/databases/$(database)/documents/conversation_authorizations/$(request.resource.data.conversation_id)).data.participant_ids
          == request.resource.data.participant_ids
        && get(/databases/$(database)/documents/conversation_authorizations/$(request.resource.data.conversation_id)).data.active
          == true
        && request.resource.data.is_read == false
        && request.resource.data.is_deleted == false;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participant_ids
        && exists(/databases/$(database)/documents/conversation_authorizations/$(resource.data.conversation_id))
        && get(/databases/$(database)/documents/conversation_authorizations/$(resource.data.conversation_id)).data.participant_ids
          == resource.data.participant_ids
        && request.resource.data.sender_id == resource.data.sender_id
        && request.resource.data.recipient_id == resource.data.recipient_id
        && request.resource.data.participant_ids == resource.data.participant_ids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'is_read', 'read_at', 'is_deleted'
        ])
        && (
          (request.auth.uid == resource.data.recipient_id
            && request.resource.data.is_deleted == resource.data.is_deleted)
          ||
          (request.auth.uid == resource.data.sender_id
            && request.resource.data.is_read == resource.data.is_read
            && request.resource.data.read_at == resource.data.read_at)
        );
      allow delete: if false;
    }

    match /conversation_authorizations/{conversationId} {
      allow read: if signedIn()
        && resource.data.participant_ids is list
        && request.auth.uid in resource.data.participant_ids;
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRead', 'readAt'
        ]);
      allow create, delete: if false;
    }

    match /payments/{document=**} {
      allow read, write: if false;
    }

    match /wallets/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /wallet_transactions/{transactionId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /payout_requests/{requestId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /copilot_rate_limits/{uid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
