# Optional compile-time configuration for web/local tooling.
# Android Firebase configuration belongs in the ignored
# android/app/google-services.json file. OpenAI keys are server secrets and
# must never be placed here.
FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_WEB_APP_ID
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE
