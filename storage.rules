rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    function safeImage() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /avatars/{uid}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid && safeImage();
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /verification_documents/{uid}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && resource == null
        && safeImage();
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
